-- =============================================================
-- SECTION 5: VERIFICATION QUERIES
-- =============================================================

PROMPT ============================================================
PROMPT VERIFICATION: All teams with their goal totals
PROMPT ============================================================
SELECT
    t.team_name,
    t.group_letter,
    wc_analytics.get_team_total_goals(t.team_id)  AS total_goals,
    wc_analytics.get_goal_difference(t.team_id)   AS goal_diff,
    wc_analytics.get_discipline_score(t.team_id)  AS discipline_score
FROM TEAM t
ORDER BY t.group_letter, total_goals DESC;

PROMPT ============================================================
PROMPT VERIFICATION: All matches with scores
PROMPT ============================================================
SELECT
    m.match_id,
    s.stage_name,
    t.team_name,
    sc.goals,
    sc.goals_conceded,
    sc.assists,
    d.yellow_cards,
    d.red_cards
FROM MATCH m
JOIN STAGE s ON m.stage_id = s.stage_id
JOIN MATCH_TEAM mt ON m.match_id = mt.match_id
JOIN TEAM t ON mt.team_id = t.team_id
LEFT JOIN MATCH_TEAM_SCORE sc ON mt.match_team_id = sc.match_team_id
LEFT JOIN MATCH_TEAM_DISCIPLINE_STATS d ON mt.match_team_id = d.match_team_id
ORDER BY m.match_id, mt.is_team1 DESC;