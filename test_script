PROMPT ============================================================
PROMPT TEST 4A: record_match_result — New valid match entry
PROMPT Inserting: Netherlands (team_id=4) vs Qatar (team_id=1), 
PROMPT a new group stage match
PROMPT ============================================================
DECLARE
    v_new_match_id MATCH.match_id%TYPE;
BEGIN
    -- First create a new match to record into
    INSERT INTO MATCH (stage_id, match_date, match_hour)
    VALUES (1, DATE '2022-11-29', '22:00')
    RETURNING match_id INTO v_new_match_id;
    COMMIT;
    DBMS_OUTPUT.PUT_LINE('Created new match ID: ' || v_new_match_id);

    -- Record Netherlands result
    wc_analytics.record_match_result(
        p_match_id       => v_new_match_id,
        p_team_id        => 4,   -- Netherlands
        p_is_team1       => 'Y',
        p_goals          => 2,
        p_goals_conceded => 0,
        p_assists        => 2,
        p_yellow_cards   => 1,
        p_red_cards      => 0,
        p_fouls          => 9
    );

    -- Record Qatar result
    wc_analytics.record_match_result(
        p_match_id       => v_new_match_id,
        p_team_id        => 1,   -- Qatar
        p_is_team1       => 'N',
        p_goals          => 0,
        p_goals_conceded => 2,
        p_assists        => 0,
        p_yellow_cards   => 2,
        p_red_cards      => 0,
        p_fouls          => 13
    );
END;
/

