    -- =============================================================
    -- IS480 - Advanced Database Management | Spring 2026
    -- FIFA World Cup 2022 - Phase 2 ETL Procedures
    -- File: etl_procedures.sql
    --
    -- Purpose:
    --   Extract data from the Phase 1 OLTP schema,
    --   transform it into star-schema format,
    --   and load it into the Phase 2 warehouse tables.
    --
    -- Warehouse grain:
    --   One row per team per match in FACT_MATCH_TEAM_PERFORMANCE.
    --
    -- Run AFTER:
    --   1. schema.sql
    --   2. warehouse_schema.sql
    -- =============================================================

    SET SERVEROUTPUT ON SIZE UNLIMITED;

    -- -------------------------------------------------------------
    -- PROCEDURE: reset_warehouse_data
    --   Clears warehouse tables in safe dependency order.
    --   This implements a full-refresh ETL pattern.
    -- -------------------------------------------------------------
    CREATE OR REPLACE PROCEDURE reset_warehouse_data AS
    BEGIN
        DELETE FROM FACT_MATCH_TEAM_PERFORMANCE;
        DELETE FROM DIM_MATCH;
        DELETE FROM DIM_DATE;
        DELETE FROM DIM_TEAM;
        DELETE FROM DIM_STAGE;
        DELETE FROM DIM_TOURNAMENT;

        COMMIT;
        DBMS_OUTPUT.PUT_LINE('[reset_warehouse_data] Warehouse tables cleared successfully.');
    EXCEPTION
        WHEN OTHERS THEN
            ROLLBACK;
            DBMS_OUTPUT.PUT_LINE('[reset_warehouse_data] ERROR: ' || SQLERRM);
            RAISE;
    END reset_warehouse_data;
    /

    -- -------------------------------------------------------------
    -- PROCEDURE: load_dim_tournament
    --   Loads the tournament dimension from OLTP TOURNAMENT.
    -- -------------------------------------------------------------
    CREATE OR REPLACE PROCEDURE load_dim_tournament AS
        v_rows_inserted NUMBER := 0;
    BEGIN
        INSERT INTO DIM_TOURNAMENT (
            tournament_id,
            tournament_name,
            tournament_year,
            host_country
        )
        SELECT
            t.tournament_id,
            t.name,
            t.year,
            t.host_country
        FROM TOURNAMENT t;

        v_rows_inserted := SQL%ROWCOUNT;
        COMMIT;
        DBMS_OUTPUT.PUT_LINE('[load_dim_tournament] Rows inserted: ' || v_rows_inserted);
    EXCEPTION
        WHEN OTHERS THEN
            ROLLBACK;
            DBMS_OUTPUT.PUT_LINE('[load_dim_tournament] ERROR: ' || SQLERRM);
            RAISE;
    END load_dim_tournament;
    /

